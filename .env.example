# App
JWT_SECRET=changeme_in_production

# Database (PostgreSQL in Docker)
DATABASE_URL=postgresql+asyncpg://app:secret@db:5432/imagedb

# S3-compatible storage — floci (local simulator)
S3_ENDPOINT_URL=http://floci:4566
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=images
S3_PUBLIC_URL=http://localhost:4566/images
S3_REGION=us-east-1

# Redis
REDIS_URL=redis://redis:6379

# Postgres (used by docker-compose db service)
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=imagedb
